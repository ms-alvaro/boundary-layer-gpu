! Boundary layer transition — TS modes inflow
! Rex_inlet=1e5, 0.2% OS eigenmodes, 3D
! DNS resolution: dx+=12, dy+=0.5, dz+=8 (Towne et al. 2022)
! Ly = 3 x delta99_est, reduced amplitude for natural transition

! Grid: nx=813, ny=125, nz=66
nxyz = 814 125 66

! Fixed time step (dt=4e-5)
CFL = -4e-5

! Viscosity: Rex_inlet = 1/1e-5 = 1e5
nu = 1e-5

! Time integration: RK2
RKscheme = 2

! No SGS model (DNS)
LES = 0

! No wall model (no-slip)
WM = 0

! No pressure gradient
dPdx = 0.0
dPdz = 0.0

! Top BC: impose velocity (Blasius)
top_flag = 0

! Blowing/suction params (not used)
Vmax = 0.0
x0 = 0.0
sigma = 1.0
phi = 0.0

! Amplitude (not used with inflow_flag=1, modes have own amplitude)
Amplitude = 0.20

! 10 flow-throughs: Lx=2, U=1, dt=4e-5 -> 50k steps/ft
nsteps   = 500000
nsave    = 5000
nstats   = 5000
nmonitor = 2500

! Blasius IC (no volume noise)
init_rand = 1

! Domain: Lx=2.0, Ly=0.41, Lz=0.1083
boxsize = 2.0 0.41 0.1083 3.0

init_step = 0

! Output
fileout =./data/BL_transition

! Inflow: Blasius + temporal modes (flag=1)
inflow_flag = 1

! Blasius self-similar solution
inflow_file =blasius_solution.dat

! Temporal modes from OS solver (TS waves)
timeinflow_file =temporal_modes_inlet.dat

! Lund params (not used)
Lund_ix = 30
Lund_deltai = 0.03
Lund_T = 0.5

! Eddy viscosity BC
nutBC = 1

! Wall stress model
TauwModel = 0
