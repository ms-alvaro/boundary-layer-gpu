! Boundary layer transition
! Rex_inlet=5e5, 20% random noise at inlet, 3D
! Long run: 10 flow-throughs

! Grid: nx=302, ny=96, nz=66
nxyz = 302 96 66

! Fixed time step
CFL = -2e-5

! Viscosity: Rex_inlet = 1/2e-6 = 5e5
nu = 2e-6

! Time integration: RK2
RKscheme = 2

! No SGS model (DNS)
LES = 0

! No wall model (no-slip)
WM = 0

! No pressure gradient
dPdx = 0.0
dPdz = 0.0

! Top BC: impose velocity (Blasius)
top_flag = 0

! Blowing/suction params (not used)
Vmax = 0.0
x0 = 0.0
sigma = 1.0
phi = 0.0

! 50% perturbation amplitude (inflow only, no IC noise)
Amplitude = 0.50

! 10 flow-throughs: Lx=5, U=1, dt=2e-5 -> 250k steps/ft
nsteps   = 1000
nsave    = 1000
nstats   = 1000
nmonitor = 100

! Blasius IC (init_flow generates Blasius; noise skipped since Amplitude_IC=0 in code)
init_rand = 1

! Domain: Lx=5, Ly=0.06, Lz=0.06
boxsize = 5.0 0.06 0.06 3.0

init_step = 0

! Output
fileout =./data/BL_transition

! Inflow: Blasius + temporal modes (flag=1)
inflow_flag = 1

! Blasius self-similar solution
inflow_file =blasius_solution.dat

! Temporal modes from OS solver (TS waves)
timeinflow_file =temporal_modes_inlet.dat

! Lund params (not used)
Lund_ix = 30
Lund_deltai = 0.03
Lund_T = 0.5

! Eddy viscosity BC
nutBC = 1

! Wall stress model
TauwModel = 0
